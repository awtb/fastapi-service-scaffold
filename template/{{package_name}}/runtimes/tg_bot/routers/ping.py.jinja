from aiogram import F
from aiogram import Router
from aiogram.filters import Command
from aiogram.types import CallbackQuery
from aiogram.types import Message

from {{ package_name }}.runtimes.tg_bot.callbacks import PingCallback
from {{ package_name }}.settings import Settings

router = Router(name="tg_bot_ping")


@router.message(Command("ping"))
async def handle_ping(message: Message, settings: Settings) -> None:
    await message.answer(f"pong:{settings.service_name}:telegram")


@router.callback_query(PingCallback.filter(F.action == "ping"))
async def handle_ping_callback(
    callback: CallbackQuery,
    callback_data: PingCallback,
    settings: Settings,
) -> None:
    await callback.answer("pong")
    if callback.message is not None:
        await callback.message.answer(
            f"pong:{settings.service_name}:{callback_data.action}"
        )
