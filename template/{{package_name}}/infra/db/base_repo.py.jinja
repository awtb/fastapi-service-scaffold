from collections.abc import Callable
from math import ceil
from typing import Any
from typing import Generic
from typing import Self
from typing import TypeVar

from sqlalchemy import func
from sqlalchemy import Select
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy.orm import noload

from {{ package_name }}.dto import PageDTO
from {{ package_name }}.exceptions import ValidationError
from {{ package_name }}.protocols import UnitOfWork

DTOT = TypeVar("DTOT")


class BaseRepository(Generic[DTOT]):
    def __init__(self, session: AsyncSession) -> None:
        self._session = session

    @classmethod
    def from_uow(cls, uow: UnitOfWork) -> Self:
        return cls(cls._get_uow_session(uow))

    @staticmethod
    def _get_uow_session(uow: UnitOfWork) -> AsyncSession:
        session = getattr(uow, "session", None)
        if session is None:
            raise TypeError(
                "SQLAlchemy repositories require a SQLAlchemy-backed unit of work."
            )
        return session

    async def _fetch(
        self,
        query: Select[Any],
        page: int,
        page_size: int,
        mapper_fn: Callable[[Any], DTOT],
    ) -> PageDTO[DTOT]:
        if page < 1:
            raise ValidationError("page must be greater than 0.")

        if page_size < 1:
            raise ValidationError("page_size must be greater than 0.")

        total = await self._session.scalar(
            query.order_by(None)
            .options(noload("*"))
            .with_only_columns(func.count(), maintain_column_froms=True)
        )
        paginated_query = query.offset((page - 1) * page_size).limit(page_size)
        rows = (await self._session.execute(paginated_query)).unique().scalars().all()
        items = [mapper_fn(item) for item in rows]
        total_items = total or 0
        total_pages = ceil(total_items / page_size) if total_items else 0

        return PageDTO(
            items=items,
            total_pages=total_pages,
            page=page,
            page_size=page_size,
            total_items=total_items,
        )
