from {{ package_name }}.features.users.dto import AuthenticateUserCommand
from {{ package_name }}.features.users.dto import AuthenticateUserResult
from {{ package_name }}.features.users.exceptions import AuthenticationError
from {{ package_name }}.features.users.protocols import AccessTokenService
from {{ package_name }}.features.users.protocols import PasswordService
from {{ package_name }}.features.users.protocols import UsersRepositoryFactory
from {{ package_name }}.protocols import UnitOfWork


class AuthenticateUserUseCase:
    def __init__(
        self,
        repository_factory: UsersRepositoryFactory,
        access_token_service: AccessTokenService,
        password_service: PasswordService,
        uow: UnitOfWork,
    ) -> None:
        self._repository_factory = repository_factory
        self._access_token_service = access_token_service
        self._password_service = password_service
        self._uow = uow

    def _normalize_email(self, email: str) -> str:
        return email.strip().lower()

    async def execute(self, command: AuthenticateUserCommand) -> AuthenticateUserResult:
        async with self._uow as uow:
            repository = self._repository_factory(uow)
            user_credentials = await repository.get_credentials_by_email(
                self._normalize_email(command.email),
            )

            if user_credentials is None or not user_credentials.user.is_active:
                raise AuthenticationError("Incorrect username or password.")

            if not self._password_service.verify(
                command.password,
                user_credentials.password_hash,
            ):
                raise AuthenticationError("Incorrect username or password.")

            return AuthenticateUserResult(
                access_token=self._access_token_service.issue_for_subject(
                    user_credentials.user.id,
                ),
                expires_in=self._access_token_service.expires_in_seconds,
            )
