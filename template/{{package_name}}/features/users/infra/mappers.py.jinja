from {{ package_name }}.infra.db.models.users import UserRecord
from {{ package_name }}.models.user import User


def create_user_record(email: str, full_name: str) -> UserRecord:
    return UserRecord(
        email=email,
        full_name=full_name,
        is_active=True,
    )


def to_user_model(record: UserRecord) -> User:
    return User(
        id=record.id,
        email=record.email,
        full_name=record.full_name,
        is_active=record.is_active,
        created_at=record.created_at,
    )
