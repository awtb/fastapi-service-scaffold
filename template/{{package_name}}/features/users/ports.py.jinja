from collections.abc import Callable
from typing import Protocol
from uuid import UUID

from {{ package_name }}.features.users.contracts import AccessToken
from {{ package_name }}.features.users.models import User
from {{ package_name }}.features.users.models import UserCredentials
from {{ package_name }}.models.page_result import PageResult
from {{ package_name }}.protocols import UnitOfWork


class UsersRepository(Protocol):
    async def get_credentials_by_email(self, email: str) -> UserCredentials | None: ...

    async def get_by_id(self, user_id: UUID) -> User | None: ...

    async def list(self, page: int, page_size: int) -> PageResult[User]: ...


class AccessTokenService(Protocol):
    def issue(self, user: User) -> AccessToken: ...

    def get_subject(self, token: str) -> UUID: ...


class PasswordService(Protocol):
    def hash(self, password: str) -> str: ...

    def verify(self, password: str, password_hash: str) -> bool: ...


UsersRepositoryFactory = Callable[[UnitOfWork], UsersRepository]
