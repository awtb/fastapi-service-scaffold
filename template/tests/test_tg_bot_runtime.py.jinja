import asyncio
from types import SimpleNamespace
from unittest.mock import AsyncMock
from unittest.mock import MagicMock

from fastapi.testclient import TestClient

from {{ package_name }}.runtimes.http.app import build_app
from {{ package_name }}.runtimes.http.lifecycle import configure_tg_bot
from {{ package_name }}.runtimes.tg_bot.dispatcher import build_dispatcher
from {{ package_name }}.runtimes.tg_bot.keyboards import build_start_keyboard
from {{ package_name }}.settings import Settings


def build_test_settings() -> Settings:
    return Settings(
        telegram_bot_token="123456:TEST_TOKEN",
        telegram_webhook_url="https://example.com/telegram",
    )


def test_tg_bot_dispatcher_registers_runtime_context() -> None:
    settings = build_test_settings()

    dispatcher = build_dispatcher(settings=settings)

    assert dispatcher["settings"] == settings
    assert set(dispatcher.resolve_used_update_types()) == {
        "callback_query",
        "message",
    }


def test_tg_bot_lifecycle_sets_commands_before_webhook() -> None:
    settings = Settings(
        telegram_bot_token="123456:TEST_TOKEN",
        telegram_webhook_url="https://example.com/telegram",
    )
    events: list[str] = []

    async def set_my_commands(_commands) -> None:
        events.append("commands")

    async def set_webhook(*, url: str) -> None:
        events.append(f"webhook:{url}")

    bot = SimpleNamespace(
        set_my_commands=set_my_commands,
        set_webhook=set_webhook,
    )

    asyncio.run(
        configure_tg_bot(
            bot=bot,
            settings=settings,
        )
    )

    assert events == [
        "commands",
        "webhook:https://example.com/telegram",
    ]


def test_telegram_webhook_endpoint_feeds_dispatcher(monkeypatch) -> None:
    monkeypatch.setenv("APP_TELEGRAM_BOT_TOKEN", "123456:TEST_TOKEN")
    monkeypatch.setenv("APP_TELEGRAM_WEBHOOK_URL", "https://example.com/telegram")
    monkeypatch.setattr(
        "{{ package_name }}.runtimes.http.lifecycle.setup_tg_bot_runtime",
        AsyncMock(return_value=None),
    )

    app = build_app()
    schedule_update = MagicMock()
    monkeypatch.setattr(
        "{{ package_name }}.runtimes.http.routers.telegram.schedule_update",
        schedule_update,
    )

    with TestClient(app) as client:
        response = client.post("/telegram", json={"update_id": 42})

    assert response.status_code == 202
    assert response.text == "ACCEPTED"
    schedule_update.assert_called_once()
    assert schedule_update.call_args.kwargs["bot"].token == "123456:TEST_TOKEN"
    assert schedule_update.call_args.kwargs["dispatcher"] is app.state.telegram_dispatcher
    assert schedule_update.call_args.kwargs["payload"] == {"update_id": 42}


def test_tg_bot_start_keyboard_contains_callback_button() -> None:
    keyboard = build_start_keyboard()

    assert keyboard.inline_keyboard[0][0].text == "Ping"
    assert keyboard.inline_keyboard[0][0].callback_data is not None
