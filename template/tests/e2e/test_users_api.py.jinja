import asyncio

from fastapi.testclient import TestClient
from sqlalchemy.ext.asyncio import async_sessionmaker
from sqlalchemy.ext.asyncio import create_async_engine

from {{ package_name }}.features.users.infra import Pbkdf2PasswordService
from {{ package_name }}.infra.db.models.user import UserRecord


async def _seed_user(database_url: str) -> str:
    engine = create_async_engine(database_url)
    session_factory = async_sessionmaker(engine, expire_on_commit=False)
    password_service = Pbkdf2PasswordService()

    try:
        async with session_factory() as session:
            user = UserRecord(
                email="user@example.com",
                full_name="Test User",
                password_hash=password_service.hash("test-password"),
                is_active=True,
            )
            session.add(user)
            await session.commit()
            await session.refresh(user)
            return str(user.id)
    finally:
        await engine.dispose()


def test_users_routes_are_exposed(client: TestClient) -> None:
    response = client.get("/openapi.json")

    assert response.status_code == 200
    paths = response.json()["paths"]
    assert "/auth/token" in paths
    assert "/users/me" in paths
    assert "/users" in paths
    assert "/users/{user_id}" in paths
    assert "post" not in paths["/users"]


def test_users_routes_require_login_and_return_records(
    client: TestClient,
    postgres_database,
) -> None:
    user_id = asyncio.run(_seed_user(postgres_database.async_url))

    unauthorized_response = client.get("/users")
    assert unauthorized_response.status_code == 401

    login_response = client.post(
        "/auth/token",
        data={
            "username": "  USER@Example.com ",
            "password": "test-password",
        },
    )

    assert login_response.status_code == 200
    token_payload = login_response.json()
    assert token_payload["token_type"] == "bearer"
    assert token_payload["expires_in"] == 1800

    headers = {"Authorization": f"Bearer {token_payload['access_token']}"}

    me_response = client.get("/users/me", headers=headers)
    assert me_response.status_code == 200
    assert me_response.json()["email"] == "user@example.com"

    list_response = client.get("/users", params={"page": 1, "page_size": 10}, headers=headers)

    assert list_response.status_code == 200
    users_page = list_response.json()
    assert users_page["total_items"] == 1
    assert users_page["page"] == 1
    assert users_page["page_size"] == 10
    assert users_page["items"][0]["id"] == user_id

    get_response = client.get(f"/users/{user_id}", headers=headers)

    assert get_response.status_code == 200
    assert get_response.json()["email"] == "user@example.com"

    invalid_password_response = client.post(
        "/auth/token",
        data={
            "username": "user@example.com",
            "password": "wrong-password",
        },
    )

    assert invalid_password_response.status_code == 401
    assert (
        invalid_password_response.json()["detail"]
        == "Incorrect username or password."
    )
